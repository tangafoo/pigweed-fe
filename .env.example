# Base URL of the pigweed backend (pigweed-be).
# Local dev: http://localhost:3000 — replace with the Railway URL once deployed.
PUBLIC_API_BASE_URL=http://localhost:3000

# Base URL of the static-assets bucket (ourlittlefarm-assets, on Cloudflare R2).
# Defaults to the public .r2.dev dev URL in code — set this to the bucket's
# custom domain in production.
PUBLIC_ASSET_BASE_URL=https://pub-9ed0a91dba4749879e89a94774f50169.r2.dev
